---
config:
  theme: base
  themeVariables:
    fontFamily: "'Open Sans', arial, sans-serif"
    primaryColor: '#cdf3ff'
    primaryTextColor: '#333E48'
    primaryBorderColor: '#007298'
    lineColor: '#45842a'
    secondaryColor: '#fff4cc'
    tertiaryColor: '#ffccd5'
---
C4Context
  title Documentation System Context
  Person(author, "Skill Author", "Maintains examples and skills.")
  System(repo, "Skills Repository", "Stores skill backlog, validators, and examples.")
  System_Ext(renderer, "Mermaid Renderer", "Renders diagram source from Markdown.")
  SystemDb_Ext(browser, "Documentation Browser", "Displays rendered diagrams.")

  Rel(author, repo, "Updates")
  Rel(repo, renderer, "Provides .mmd and .md files")
  Rel(renderer, browser, "Publishes SVG output")
  Rel(author, browser, "Reviews")

  UpdateElementStyle(author, $bgColor="#cdf3ff", $fontColor="#333E48", $borderColor="#007298")
  UpdateElementStyle(repo, $bgColor="#dbffcc", $fontColor="#333E48", $borderColor="#45842a")
  UpdateElementStyle(renderer, $bgColor="#fff4cc", $fontColor="#333E48", $borderColor="#e77204")
  UpdateElementStyle(browser, $bgColor="#f9ccff", $fontColor="#333E48", $borderColor="#9e1b32")
  UpdateRelStyle(repo, renderer, $textColor="#45842a", $lineColor="#45842a")
  UpdateLayoutConfig($c4ShapeInRow="2", $c4BoundaryInRow="1")
