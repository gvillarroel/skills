---
config:
  theme: base
  themeVariables:
    fontFamily: "'Open Sans', arial, sans-serif"
    primaryColor: '#cdf3ff'
    primaryTextColor: '#333E48'
    primaryBorderColor: '#007298'
    lineColor: '#45842a'
    secondaryColor: '#fff4cc'
    tertiaryColor: '#f9ccff'
---
block
  columns 4
  source[".mmd source"]
  arrow1<["render"]>(right)
  markdown(["Markdown wrapper"])
  arrow2<["check"]>(right)
  result(("Pass"))
  space:4
  palette{{"Theme variables"}}
  arrow3<["shape"]>(up)
  diagram[("Diagram type")]
  arrow4<["reuse"]>(left)

  source --> markdown
  markdown --> result
  palette --> diagram

  style source fill:#cdf3ff,stroke:#007298,stroke-width:2px
  style markdown fill:#dbffcc,stroke:#45842a,stroke-width:2px
  style palette fill:#fff4cc,stroke:#e77204,stroke-width:2px
  style result fill:#f9ccff,stroke:#9e1b32,stroke-width:2px
