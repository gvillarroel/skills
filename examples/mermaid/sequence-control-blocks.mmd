---
config:
  theme: base
  sequence:
    showSequenceNumbers: true
    mirrorActors: true
    actorMargin: 56
  themeVariables:
    fontFamily: "'Open Sans', arial, sans-serif"
    actorBkg: '#cdf3ff'
    actorBorder: '#007298'
    actorTextColor: '#333E48'
    activationBkgColor: '#fff4cc'
    activationBorderColor: '#e77204'
    sequenceNumberColor: '#45842a'
    noteBkgColor: '#dbffcc'
    noteBorderColor: '#45842a'
---
sequenceDiagram
  autonumber
  box rgba(205, 243, 255, 0.35) Front door
    actor User
    participant UI
  end
  box rgba(255, 244, 204, 0.45) Platform
    participant API
    participant Queue
    participant Worker
  end
  participant Store
  participant Audit

  rect rgba(249, 204, 255, 0.18)
    User->>UI: Upload import file
    activate UI
    UI->>API: POST /imports
    critical Reserve import slot
      API->>Queue: Create job
    option Slot unavailable
      API-->>UI: Retry later
    end

    alt File has warnings
      API-->>UI: Accepted with warnings
      opt User opens detail drawer
        UI->>API: GET /imports/{id}/warnings
        API-->>UI: Warning list
      end
    else File rejected
      API-->>UI: Validation errors
    else File accepted
      par Queue worker
        Queue->>Worker: Dispatch job
        Worker->>Store: Write normalized rows
      and Audit stream
        API->>Audit: Record receipt
      end
    end
    deactivate UI
  end
