---
config:
  theme: base
  themeVariables:
    fontFamily: "'Open Sans', arial, sans-serif"
    primaryColor: '#f9ccff'
    primaryTextColor: '#333E48'
    primaryBorderColor: '#652f6c'
    lineColor: '#45842a'
    secondaryColor: '#ffe5cc'
    tertiaryColor: '#dbffcc'
---
classDiagram
  direction LR
  class DiagramCatalog {
    +string name
    +addExample(example)
    +validate()
  }
  class MermaidExample {
    +string diagramType
    +string sourceFile
    +render()
  }
  class ThemeConfig {
    +string primaryColor
    +string lineColor
    +apply()
  }
  class ShapePalette {
    +string defaultShape
    +assign(nodeId, shape)
  }

  DiagramCatalog "1" o-- "*" MermaidExample
  MermaidExample --> ThemeConfig
  MermaidExample --> ShapePalette
  ThemeConfig <|-- FrontmatterTheme

  style MermaidExample fill:#cdf3ff,stroke:#007298,color:#333E48
  style DiagramCatalog fill:#cdf3ff,stroke:#007298,color:#333E48
  style ShapePalette fill:#fff4cc,stroke:#994a00,color:#333E48

