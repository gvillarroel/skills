---
config:
  theme: base
  layout: elk
  look: handDrawn
  themeVariables:
    fontFamily: "'Open Sans', arial, sans-serif"
    primaryColor: '#cdf3ff'
    primaryTextColor: '#333E48'
    primaryBorderColor: '#007298'
    lineColor: '#45842a'
    secondaryColor: '#fff4cc'
    tertiaryColor: '#dbffcc'
---
flowchart LR
  start(("Start")) --> collect[/Collect request/]
  collect --> validate{"Valid payload?"}
  validate -->|yes| persist[("Store event")]
  validate -->|no| repair["Repair input"]
  repair --> collect
  persist --> notify(["Notify subscriber"])
  notify --> done((("Done")))

  classDef focus fill:#fff4cc,stroke:#994a00,color:#333E48,stroke-width:2px;
  class validate,persist focus;

