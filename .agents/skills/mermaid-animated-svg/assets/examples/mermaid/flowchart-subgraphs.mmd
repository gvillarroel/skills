---
config:
  theme: base
  layout: elk
  look: handDrawn
  themeVariables:
    fontFamily: "'Open Sans', arial, sans-serif"
    primaryColor: '#cdf3ff'
    primaryTextColor: '#333E48'
    primaryBorderColor: '#007298'
    lineColor: '#652f6c'
    secondaryColor: '#fff4cc'
    tertiaryColor: '#dbffcc'
---
flowchart TB
  subgraph intake["Edge intake"]
    direction LR
    file[/CSV file/]
    scan{{"Scan<br/>headers"}}
    quarantine>"Quarantine<br/>record"]
  end

  subgraph core["Validation core"]
    direction TB
    schema{"Schema ok?"}
    rules[["Rule engine"]]
    dedupe[("Dedupe cache")]
  end

  subgraph publish["Publish"]
    direction LR
    event(["Accepted event"])
    topic((Kafka topic))
  end

  file o--o scan
  scan --> schema
  schema ==>|yes| rules
  schema -.->|no| quarantine
  rules --> dedupe
  dedupe x--x quarantine
  dedupe --> event
  event --> topic
  quarantine -.->|manual review| file

  classDef decision fill:#fff4cc,stroke:#e77204,color:#333E48,stroke-width:2px;
  classDef store fill:#dbffcc,stroke:#45842a,color:#333E48,stroke-width:2px;
  class schema,scan decision;
  class dedupe,topic store;
