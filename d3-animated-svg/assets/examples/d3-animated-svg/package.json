{
  "name": "d3-animated-svg",
  "private": true,
  "scripts": {
    "verify": "npm run verify:beeswarm && npm run verify:gallery",
    "verify:beeswarm": "uv run --script ../../../scripts/render_d3_svg.py force-beeswarm.html -o ../../../../output/d3-animated-svg/force-beeswarm.svg --screenshot ../../../../output/d3-animated-svg/force-beeswarm.png --wait-ms 1800",
    "verify:gallery": "uv run --script ../../../scripts/verify_d3_gallery.py index.html --expected 202 --screenshot ../../../../output/d3-animated-svg/gallery.png --wait-ms 2200",
    "serve": "python -m http.server 4177"
  },
  "dependencies": {
    "d3": "^7.9.0",
    "d3-sankey": "^0.12.3"
  }
}
