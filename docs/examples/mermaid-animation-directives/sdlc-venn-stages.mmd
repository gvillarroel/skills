---
config:
  theme: base
  themeVariables:
    fontFamily: "'Open Sans', arial, sans-serif"
    primaryColor: '#cdf3ff'
    primaryTextColor: '#333E48'
    primaryBorderColor: '#007298'
    lineColor: '#45842a'
    secondaryColor: '#fff4cc'
    tertiaryColor: '#f9ccff'
---
venn-beta
  title "Linear SDLC Overlaps"
  set Discover["Discover"]:26
  set Design["Design"]:26
  set Build["Build"]:26
  set Verify["Verify"]:26
  set Operate["Operate"]:26
  union Discover,Design["Scope"]:12
  union Design,Build["Blueprint"]:12
  union Build,Verify["Test Loop"]:12
  union Verify,Operate["Release"]:12
  style Discover fill:#cdf3ff,stroke:#007298,color:#333E48,fill-opacity:0.66
  style Design fill:#dbffcc,stroke:#45842a,color:#333E48,fill-opacity:0.66
  style Build fill:#fff4cc,stroke:#994a00,color:#333E48,fill-opacity:0.7
  style Verify fill:#ffd8e8,stroke:#b02564,color:#333E48,fill-opacity:0.66
  style Operate fill:#e6dcff,stroke:#6648a8,color:#333E48,fill-opacity:0.66

