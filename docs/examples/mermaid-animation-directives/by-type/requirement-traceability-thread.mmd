---
config:
  theme: base
  themeVariables:
    fontFamily: "'Open Sans', arial, sans-serif"
    primaryColor: '#f9ccff'
    primaryTextColor: '#333E48'
    primaryBorderColor: '#652f6c'
    lineColor: '#45842a'
    secondaryColor: '#fff4cc'
    tertiaryColor: '#f9ccff'
---
requirementDiagram
  direction LR
  requirement diagram_examples {
    id: "EX-001"
    text: "Provide paired Mermaid source and Markdown render examples."
    risk: medium
    verifymethod: inspection
  }
  functionalRequirement frontmatter_config {
    id: "EX-002"
    text: "Use YAML frontmatter to customize colors."
    risk: low
    verifymethod: test
  }
  element examples_folder {
    type: "repository folder"
    docref: "examples/mermaid"
  }
  examples_folder - satisfies -> diagram_examples
  frontmatter_config - derives -> diagram_examples

  classDef important fill:#cdf3ff,stroke:#007298,stroke-width:2px,color:#333E48
  class diagram_examples,frontmatter_config important

